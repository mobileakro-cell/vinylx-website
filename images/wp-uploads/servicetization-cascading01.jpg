    .r__shape:after {
    content: "";
    background-color: #E9204F;
    height: 70px;
    width: calc( 100% + 20px );
    position: absolute;
    bottom: -20px;
    z-index: -1;
}
.r2__shape:after {
    content: "";
    background-color: #E9204F;
    height: 100px;
    width: 100px;
